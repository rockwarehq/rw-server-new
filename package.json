{
  "name": "rw-server-new",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && tsc -p apps/api",
    "clean": "tsc -b --clean",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @rw/db prisma:generate",
    "db:migrate": "pnpm --filter @rw/db prisma:migrate",
    "db:migrate:dev": "pnpm --filter @rw/db prisma:migrate:dev",
    "db:seed": "pnpm --filter @rw/db seed",
    "fly:deploy": "tsx scripts/fly-deploy.ts",
    "fly:generate": "tsx scripts/fly-deploy.ts --generate-only"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/node": "^24.10.8",
    "smol-toml": "^1.6.0",
    "tsx": "^4.19.4",
    "typescript": "~6.0.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.28.0"
}
