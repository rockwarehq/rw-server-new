{
  "name": "@rw/workers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "start:rollups": "node dist/main.js --worker rollups",
    "start:processor": "node dist/main.js --worker processor",
    "start:processor-consumer": "node dist/main.js --worker processor-consumer",
    "dev:rollups": "tsx watch src/main.ts --worker rollups",
    "dev:processor": "tsx watch src/main.ts --worker processor",
    "dev:processor-consumer": "tsx watch src/main.ts --worker processor-consumer"
  },
  "dependencies": {
    "@orpc/client": "^1.14.3",
    "@orpc/server": "^1.14.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@rw/db": "workspace:*",
    "@rw/services": "workspace:*",
    "@rw/runtime": "workspace:*",
    "better-result": "^2.9.2",
    "bullmq": "^5.66.5",
    "dotenv": "^17.2.3",
    "ioredis": "^5.10.1",
    "mqtt": "^5.14.1",
    "prom-client": "^15.1.3",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.8",
    "@types/uuid": "^11.0.0",
    "tsx": "^4.19.4",
    "typescript": "~6.0.2"
  }
}
